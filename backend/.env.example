# Backend Environment Variables Template
# Copy this file to appropriate location and fill in actual values

# === Database Configuration ===
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:mysql://localhost:3306/GoHommiesDB
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=540000
DB_KEEPALIVE_TIME_MS=300000

# === JWT Configuration ===
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-recommended
JWT_EXPIRATION_MS=36000000

# === Cloudinary (Image Upload) ===
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === AI Services ===
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# === CORS Configuration ===
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# === Email Configuration (Optional) ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM=your_email@gmail.com

# === JPA Configuration ===
SPRING_JPA_HIBERNATE_DDL_AUTO=update
FLYWAY_ENABLED=false

# === Logging ===
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_GOHOMMIES=DEBUG

# === Server Configuration ===
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api
