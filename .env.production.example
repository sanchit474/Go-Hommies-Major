# Production Environment Variables
# Sensitive data - DO NOT commit to git
# Update all values before deploying to production

# === Application Profiles ===
SPRING_PROFILES_ACTIVE=prod

# === Database Configuration (TiDB Cloud) ===
# Get credentials from TiDB Cloud console
DB_URL=jdbc:mysql://gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/GoHommiesDB?useSSL=true&serverTimezone=UTC
DB_USERNAME=your_tidb_username
DB_PASSWORD=your_tidb_password
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=540000

# === JWT Configuration ===
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-production-secret-key-at-least-32-characters-long-here
JWT_EXPIRATION_MS=86400000

# === Cloudinary Configuration ===
CLOUDINARY_CLOUD_NAME=your_cloudinary_account
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# === AI Services ===
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# === CORS Configuration ===
# Frontend and Admin domains
APP_CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com

# === Email Configuration ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM=your_email@gmail.com

# === Frontend & Admin Configuration ===
VITE_API_BASE_URL=https://api.yourdomain.com

# === Docker Container Ports ===
BACKEND_PORT=8080
FRONTEND_PORT=3000
ADMIN_PORT=3001

# === Logging ===
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_GOHOMMIES=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
